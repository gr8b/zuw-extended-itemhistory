{
	"manifest_version": 2.0,
	"id": "extendeditemhistory",
	"type": "widget",
	"name": "Extended item history",
	"namespace": "ExtendedItemHistory",
	"version": "1.0",
	"author": "Zabbix",
	"description": "Displays the latest data for the selected items with an option to add progress bar visualizations, customize report columns, and display images for binary data types.",
	"url": "web_interface/frontend_sections/dashboards/widgets/item_history",
	"widget": {
		"size": {
			"width": 18,
			"height": 6
		},
		"js_class": "ExtendedItemHistory_CWidgetItemHistory",
		"in": {
			"time_period": {
				"type": "_timeperiod"
			}
		},
		"out": [
			{
				"type": "_itemid"
			},
			{
				"type": "_itemids"
			}
		]
	},
	"actions": {
		"widget.extendeditemhistory.view": {
			"class": "WidgetView"
		},
		"widget.extendeditemhistory.column.edit": {
			"class": "ColumnEdit",
			"view": "column.edit",
			"layout": "layout.json"
		},
		"widget.extendeditemhistory.value.check": {
			"class": "ValueCheck",
			"layout": "layout.json"
		},
		"widget.extendeditemhistory.binary_value.get": {
			"class": "BinaryValueGet",
			"layout": "layout.json"
		},
		"widget.extendeditemhistory.image_value.get": {
			"class": "ImageValueGet",
			"layout": "layout.image"
		}
	},
	"assets": {
		"js": [
			"class.widget.js"
		]
	}
}
